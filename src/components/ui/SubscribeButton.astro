<dialog id="modal" class="subscribe-modal">
  <button class="close-btn" type="button" commandfor="modal" command="close">×</button>

  <h2 class="title">Suscríbete</h2>

  <form
    action="https://buttondown.com/api/emails/embed-subscribe/bleepculture"
    method="post"
    class="subscribe-method"
  >
    <div>
      <label for="bd-email">Vía Email</label>
      <p>
        Te enviaré un correo cada vez que publique algo nuevo, si publico muchas cosas las agruparé.
      </p>
    </div>

    <input type="email" name="email" id="bd-email" placeholder="Escribe tu email" />

    <button class="active-button medium w-full" type="submit">Suscribirse por Email</button>
  </form>

  <hr class="hr-text gradient" data-content="o" />

  <div class="subscribe-method">
    <div>
      <h3>Vía RSS</h3>
      <p>Para los amantes de esta arcaica y revolucionaría tecnología.</p>
    </div>

    <button class="active-button medium w-full" type="button" id="subscribe-via-rss"
      >Suscribirse por RSS</button
    >
  </div>
</dialog>

<button
  class="active-button medium subscribe-button"
  type="button"
  commandfor="modal"
  command="show-modal"
>
  Suscríbete
</button>

<style is:inline>
  /* Lock the page */
  body:has(dialog[open]) {
    overflow: hidden; /* fallback for older browsers */
    overscroll-behavior: none;
  }

  dialog[open],
  dialog[open]::backdrop {
    backdrop-filter: blur(1px);
    overscroll-behavior: contain;
  }

  .subscribe-button {
    margin-bottom: 0.4rem;
  }

  .active-button {
    display: flex;
    width: fit-content;
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    cursor: pointer;
    border-radius: var(--rounded-sm);
    text-wrap: nowrap;
    align-items: center;
    justify-content: center;
    line-height: 1;
    font-family: var(--font-ui);
    font-weight: 400;

    padding: 2px 4px;
    font-size: var(--font-size-s);

    &.medium {
      font-size: var(--font-size-m);
      padding: 6px 24px;
      height: 32px;
    }

    &.w-full {
      width: 100%;
    }

    &:hover,
    &:focus {
      color: var(--text-primary);
      background: var(--bg-tertiary);
      border: 1px solid var(--border-active);
      outline: none;
    }
  }

  .subscribe-modal[open=''] {
    display: flex;
    flex-direction: column;
    width: 60ch;
    height: fit-content;

    background: var(--bg);
    border: 1px solid var(--border-active);
    border-radius: var(--rounded-sm);
    text-color: var(--text-primary);

    & .title {
      color: var(--text-primary);
      font-weight: 500;
      font-size: 1.6rem;
      margin: 0;
      padding: 0;
      margin-top: -2rem;
      width: fit-content;
    }

    & .close-btn {
      background: none;
      border: none;
      padding: 0;
      margin-left: auto;
      width: fit-content;
      cursor: pointer;
      font-size: var(--font-size-xl);
      user-select: none;
    }
  }

  .subscribe-method {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin: 0.8rem 0;

    & input {
      border: none;
      background-image: none;
      background-color: transparent;
      -webkit-box-shadow: none;
      -moz-box-shadow: none;
      box-shadow: none;
      appearance: none;
      border-radius: var(--rounded-sm);
      border: 1px solid var(--border);
      background-color: var(--bg-secondary);
      outline: none;
      font-size: var(--font-size-m);
      padding: 4px 8px;
      color: var(--text-primary);

      &:focus,
      &:hover {
        color: var(--text-primary);
        outline: none;
        background: var(--bg-tertiary);
        border: 1px solid var(--border-active);
      }

      &::placeholder {
        color: var(--text-secondary);
      }
    }

    & div {
      & h3,
      p,
      label {
        padding: 0;
        margin: 0;
        line-height: 1.4;
      }

      & h3,
      label {
        color: var(--text-primary);
        font-weight: 500;
        font-size: var(--font-size-l);
        line-height: 1.8;
      }
    }

    & p {
      color: var(--text-secondary);
      font-size: var(--font-size-m);
      line-height: 1.4;
      font-wrap: balance;
      overflow-wrap: break-word;
    }
  }

  .hr-text {
    border: 0;
    line-height: 1em;
    position: relative;
    text-align: center;
    height: 1.5em;
    font-size: 14px;
    margin: 20px 0;
  }

  .hr-text::before {
    content: '';
    background: var(--border);
    position: absolute;
    left: 0;
    top: 50%;
    width: 100%;
    height: 1px;
  }

  .hr-text::after {
    content: attr(data-content);
    position: relative;
    padding: 0 7px;
    line-height: 1.5em;
    color: var(--text-tertiary);
    background-color: var(--bg);
  }
</style>

<script>
  const subscribeFeedButton = document.getElementById('subscribe-via-rss')

  subscribeFeedButton?.addEventListener('click', () => {
    window.navigator.clipboard.writeText('https://vicente015.dev/rss.xml')
    subscribeFeedButton.textContent = '¡Enlace copiado al portapapeles!'
  })
</script>
