---
import type { CollectionEntry } from 'astro:content'
import dayjs from 'dayjs'
import localizedPlugin from 'dayjs/plugin/localizedFormat'
import removeMarkdown from 'remove-markdown'
import { Image } from 'astro:assets'
import path from 'node:path'
import LocationIcon from '@lucide/astro/icons/map-pin'
import HeartIcon from '@lucide/astro/icons/heart'

import('dayjs/locale/es')

dayjs.extend(localizedPlugin)
dayjs.locale('es')

const { post } = Astro.props as { post: CollectionEntry<'posts'> }

let images =
  post.rendered?.metadata?.imagePaths.map(
    (imagePath) =>
      '@fs' +
      path.resolve(
        path.join(post.filePath!.split('/').slice(0, -1).join('/'), imagePath.replace('./', '/'))
      )
  ) ?? []

images = images.slice(0, 4)

const cleanBody = removeMarkdown(post.body!)
const lines = cleanBody.trim().split('\n')
const preview = lines.slice(0, 5).join('\n')
---

<article class="postPreview">
  <header class="header">
    <a href={`/${post.id}/`}>
      {
        images && images.length > 0 && (
          <div class="gallery">
            {images.map((imgPath) => {
              return <Image src={imgPath} alt={imgPath} />
            })}
          </div>
        )
      }
    </a>
  </header>

  <main class="summary">
    <p><span class="title">{post.data.title}</span> {preview}</p>
  </main>

  <footer class="footer">
    <a href={`/${post.id}/`}>
      <span class="publishDate">
        {dayjs(post.data.pubDate).format('DD MMMM')}
      </span>
    </a>

    {
      post.data.location && (
        <div class="location">
          <LocationIcon size="1.1em" stroke-width={1.2} />
          <span>{post.data.location}</span>
        </div>
      )
    }

    {
      post.data.likes && (
        <div class="likes">
          <HeartIcon size="1.1em" stroke-width={1.2} />
          <span>{post.data.likes}</span>
        </div>
      )
    }
  </footer>
</article>

<style is:inline>
  .icon {
    display: inline-block;
    width: 1em;
    height: 1em;
    color: var(--text-tertiary);
  }

  .postPreview {
    display: flex;
    flex-direction: column;

    & .header {
      margin-bottom: var(--spacing-s);
    }

    & .gallery {
      display: grid;
      max-height: 320px;
      border-radius: 6px;
      overflow: hidden;
      margin: 12px -1rem;
      border: 1px solid var(--border);
      gap: 1px;
      background: var(--border);

      &:first-of-type {
        margin-top: 0;
      }

      & img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    }

    & .gallery:has(> :last-child:nth-child(1)) {
      grid-template-columns: 1fr;
      grid-template-rows: minmax(0, 320px);
    }

    & .gallery:has(> :last-child:nth-child(2)) {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: minmax(0, 320px);
    }

    & .gallery:has(> :last-child:nth-child(3)) {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;

      & > :nth-child(1) {
        grid-column: 1;
        grid-row: 1 / 3;
      }

      & > :nth-child(2) {
        grid-column: 2;
        grid-row: 1;
      }

      & > :nth-child(3) {
        grid-column: 2;
        grid-row: 2;
      }
    }

    & .gallery:has(> :last-child:nth-child(4)) {
      grid-template-columns: 1fr 1fr 1fr 1fr;
      grid-template-rows: 1fr 1fr;

      & > :nth-child(1) {
        grid-column: 1 / 3;
        grid-row: 1 / 3;
      }

      & > :nth-child(2) {
        grid-column: 3 / 5;
        grid-row: 1;
      }

      & > :nth-child(3) {
        grid-column: 3;
        grid-row: 2;
      }

      & > :nth-child(4) {
        grid-column: 4;
        grid-row: 2;
      }
    }

    & .title {
      &::after {
        content: ' ― ';
      }

      color: var(--text-primary);
      font-weight: 700;
      font-size: var(--font-size-m);
      -webkit-line-clamp: 3;
      text-wrap: pretty;
      font-style: italic;
      overflow-wrap: break-word;
      margin: 0;
      padding: 0;
    }

    & .summary {
      color: var(--text-primary);
      font-size: var(--font-size-m);
      line-height: var(--leading-normal);
      overflow-wrap: break-word;
      padding: 0 var(--content-padding);

      overflow: hidden;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;

      & p {
        margin: 0.2rem 0;
        padding: 0;
        text-align: justify;
      }
    }

    & .footer {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 12px;
      color: var(--text-tertiary);
      margin: 0;
      padding: 0 var(--content-padding);

      & a {
        text-decoration: none;
      }

      & .location {
        display: flex;
        flex-direction: row;
        gap: 4px;
        align-items: center;

        & span {
          color: var(--text-secondary);
          padding: 0;
          margin: 0;
          font-size: var(--font-size-m);
          line-height: 1;
        }
      }

      & .likes {
        display: flex;
        flex-direction: row;
        gap: 4px;
        align-items: center;

        & span {
          padding: 0;
          margin: 0;
          font-size: var(--font-size-m);
          line-height: 1;
        }
      }

      & .publishDate {
        color: var(--text-secondary);
        font-size: var(--font-size-m);
      }
    }
  }
</style>
