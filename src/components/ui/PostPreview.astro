---
import removeMarkdown from 'remove-markdown'
import { Image } from 'astro:assets'

import type { postsWithPhotos } from '@/utils/postWithPhotos'
import PostFooter from './PostFooter.astro'

const { post } = Astro.props as { post: (typeof postsWithPhotos)[number] }

const cleanBody = removeMarkdown(post.body!)
const lines = cleanBody.trim().split('\n')
const preview = lines.slice(0, 5).join('\n')
---

<article class="postPreview">
  <header class="header">
    <a href={`/${post.id}/`}>
      {
        post.photos && post.photos.length > 0 && (
          <div class="gallery">
            {post.photos.map(([_, mod]) => {
              return <Image src={mod()} alt={''} />
            })}
          </div>
        )
      }
    </a>
  </header>

  <main class="summary">
    <p><span class="title">{post.data.title}</span> {preview}</p>
  </main>

  <PostFooter post={post} />
</article>

<style>
  .icon {
    display: inline-block;
    width: 1em;
    height: 1em;
    color: var(--text-tertiary);
  }

  .postPreview {
    display: flex;
    flex-direction: column;

    & .header {
      margin-bottom: var(--spacing-s);
    }

    & .gallery {
      display: grid;
      height: 320px;
      overflow: hidden;
      border-radius: 6px;
      margin: 12px -1rem;
      border: 1px solid var(--border);
      background: var(--border);

      &:first-of-type {
        margin-top: 0;
      }

      & img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    }

    & .gallery:has(> :last-child:nth-child(1)) {
      grid-template-columns: 1fr;
      grid-template-rows: minmax(0, 320px);
    }

    & .gallery:has(> :last-child:nth-child(2)) {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: minmax(0, 320px);
    }

    & .gallery:has(> :last-child:nth-child(3)) {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: minmax(160px, 1fr);

      & > :nth-child(1) {
        grid-column: 1;
        grid-row: 1 / 3;
      }

      & > :nth-child(2) {
        grid-column: 2;
        grid-row: 1;
      }

      & > :nth-child(3) {
        grid-column: 2;
        grid-row: 2;
      }
    }

    & .gallery:has(> :last-child:nth-child(4)) {
      grid-template-columns: 1fr 1fr 1fr 1fr;
      grid-template-rows: minmax(160px, 1fr);

      & > :nth-child(1) {
        grid-column: 1 / 3;
        grid-row: 1 / 3;
      }

      & > :nth-child(2) {
        grid-column: 3 / 5;
        grid-row: 1;
      }

      & > :nth-child(3) {
        grid-column: 3;
        grid-row: 2;
      }

      & > :nth-child(4) {
        grid-column: 4;
        grid-row: 2;
      }
    }

    & .title {
      &::after {
        content: ' ― ';
      }

      color: var(--text-primary);
      font-weight: 700;
      font-size: var(--font-size-m);
      -webkit-line-clamp: 3;
      text-wrap: pretty;
      font-style: italic;
      overflow-wrap: break-word;
      margin: 0;
      padding: 0;
    }

    & .summary {
      color: var(--text-primary);
      font-size: var(--font-size-m);
      line-height: var(--leading-normal);
      overflow-wrap: break-word;
      padding: 0 var(--content-padding);

      overflow: hidden;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;

      & p {
        margin: 0.2rem 0;
        padding: 0;
        text-align: justify;
      }
    }
  }
</style>
