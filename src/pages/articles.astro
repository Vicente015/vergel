---
import About from '@/components/widgets/About.astro'
import Navbar from '@/components/ui/Navbar.astro'
import SubscribeButton from '@/components/ui/SubscribeButton.astro'
import IndexLayout from '@/layouts/IndexLayout.astro'
import PostList from '@/components/widgets/PostList.astro'
import { getArticles } from '@/utils/articles'
import { themeConfig } from '@/config'

const posts = await getArticles()
---

<IndexLayout
  title={`Artículos — ${themeConfig.site.title}`}
  description={themeConfig.site.description}
>
  <About />

  <div class="nav">
    <Navbar />
    <SubscribeButton />
  </div>

  <main>
    <PostList posts={posts} />
  </main>
</IndexLayout>

<style>
  .nav {
    display: flex;
    align-items: start;
    justify-content: space-between;
    flex-wrap: wrap;
    margin-top: 1rem;
    gap: 0.5rem;
    margin-bottom: 0.8rem;
  }
</style>
