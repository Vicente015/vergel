---
import Navbar from '@/components/ui/Navbar.astro'
import SubscribeButton from '@/components/ui/SubscribeButton.astro'
import IndexLayout from '@/layouts/IndexLayout.astro'
import { Image } from 'astro:assets'

const images = import.meta.glob('../content/posts/_assets/*.{jpg,jpeg,png}', {
  eager: true
})
console.debug(images)
---

<IndexLayout>
  <div class="nav">
    <Navbar />
    <SubscribeButton />
  </div>

  <main class="gallery">
    {
      Object.entries(images)
        .concat(Object.entries(images))
        .concat(Object.entries(images))
        .concat(Object.entries(images))
        .map(([path, mod]) => <Image src={mod.default.src} alt={''} />)
    }
  </main>
</IndexLayout>

<style is:inline>
  .gallery {
    display: grid;
    gap: 0.4rem;
    row-gap: 0.4rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    grid-template-rows: repeat(2, 1fr);

    & img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      aspect-ratio: 1 / 1;
      border-radius: var(--rounded-sm);

      &:hover {
        cursor: zoom-in;
      }
    }
  }

  .nav {
    display: flex;
    align-items: start;
    justify-content: space-between;
    height: 32px;
    margin-top: 1rem;
    margin-bottom: 0.8rem;
  }
</style>
